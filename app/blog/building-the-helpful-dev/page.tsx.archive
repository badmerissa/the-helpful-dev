      </section>

      {/* ── Article body ── */}
      <div className="max-w-3xl mx-auto px-6 pb-20">

        {/* Table of Contents */}
        <nav className="bg-slate-50 border border-slate-200 rounded-2xl px-7 py-6 my-10">
          <h3 className="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-4">
            In this post
          </h3>
          <ol className="space-y-2 pl-5 list-decimal">
            {[
              ["#context", "What The Helpful Dev actually is"],
              ["#v1", "v1: The humble card grid (January 2026)"],
              ["#v2", "v2: The commercial redesign — and the same-day color crisis"],
              ["#logo", "The logo that arrived at 7 AM"],
              ["#seo-audit", "The SEO and quality grind"],
              ["#v3", "v3: Stop being a portfolio, start being a journey"],
              ["#ai-angle", "How AI-assisted development shaped every iteration"],
              ["#takeaways", "Key takeaways"],
            ].map(([href, label]) => (
              <li key={href}>
